# ==========================================
# THE AYOTUNDE OSO FOUNDATION
# Environment Variables Reference
# ==========================================
# Copy this file to .env.local and fill in
# all values before running the application.
# NEVER commit .env.local to version control.
# ==========================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="The Ayotunde Oso Foundation"
NEXT_PUBLIC_APP_DESCRIPTION="Empowering people. Transforming communities."
NEXT_PUBLIC_SUPPORT_EMAIL=support@ayotundeosofoundation.org

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/ayotunde_foundation?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/ayotunde_foundation?schema=public"

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Paystack Payments
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...

# Flutterwave Payments
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_ENCRYPTION_KEY=...

# Anthropic AI (KOMAI)
ANTHROPIC_API_KEY=sk-ant-...
KOMAI_MODEL=claude-sonnet-4-6
KOMAI_MAX_TOKENS=2048

# Redis Cache (Upstash)
REDIS_URL=redis://...
REDIS_TOKEN=...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@ayotundeosofoundation.org
EMAIL_REPLY_TO=info@ayotundeosofoundation.org

# Cloudinary Media
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=...

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=...

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=...

# Security
NEXTAUTH_SECRET=generate-a-secure-random-string-here
CSRF_SECRET=generate-another-secure-random-string

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Feature Flags
NEXT_PUBLIC_ENABLE_KOMAI=true
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Social Media
NEXT_PUBLIC_TWITTER_HANDLE=@AyotundeOsoFdn
NEXT_PUBLIC_FACEBOOK_PAGE=AyotundeOsoFoundation
NEXT_PUBLIC_INSTAGRAM_HANDLE=ayotundeosofoundation
NEXT_PUBLIC_LINKEDIN_PAGE=ayotunde-oso-foundation
NEXT_PUBLIC_YOUTUBE_CHANNEL=@AyotundeOsoFoundation
